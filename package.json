{
  "name": "elo2026-exhibition-preview",
  "version": "0.8.0",
  "private": true,
  "type": "module",
  "homepage": "https://projects.cah.ucf.edu/mediaartsexhibits/elo2026",
  "dependencies": {
    "@citation-js/core": "^0.8.1",
    "@citation-js/plugin-bibtex": "^0.8.1",
    "@citation-js/plugin-csl": "^0.8.1",
    "@fontsource/exo": "^5.2.8",
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.8",
    "dompurify": "^3.4.12",
    "i18n-iso-countries": "^7.14.0",
    "loc-marc-relators": "^1.0.0",
    "marked": "^18.0.6",
    "react": "^19.2.7",
    "react-bootstrap": "^2.10.10",
    "react-bootstrap-icons": "^1.11.6",
    "react-dom": "^19.2.7",
    "react-fout-stager": "^3.0.0",
    "react-helmet-async": "^3.0.0",
    "react-router": "^8.2.0",
    "react-router-dom": "^7.18.1",
    "sass": "^1.101.0",
    "zod": "^4.4.3"
  },
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "build:ssr": "vite build --ssr src/entry-server.tsx",
    "prerender": "node scripts/prerender.mjs",
    "build:full": "npm run build:works && npm run build && npm run build:ssr && npm run prerender && rm -rf dist-ssr",
    "type-check": "tsc",
    "preview": "vite preview",
    "test": "vitest run --coverage",
    "lint": "eslint src --ext .ts,.tsx --fix",
    "build:works": "tsx scripts/build-works.mts",
    "validate": "tsx scripts/validate-works.mts",
    "verify:videos": "node scripts/verify-deployed-videos.mjs",
    "shrink:videos": "node scripts/shrink-videos.mjs",
    "predeploy:gh": "VITE_APP_BASE_PATH=/elo2026-exhibition-preview/ npm run build:full",
    "deploy:gh": "gh-pages -d build",
    "all": "npm run build:works && npm run lint && npm run type-check && npm run validate && npm run test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "gh-pages": "^6.3.0",
    "globals": "^17.7.0",
    "gray-matter": "^4.0.3",
    "jsdom": "^29.1.1",
    "tsx": "^4.23.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.10",
    "vitest-axe": "^0.1.0"
  },
  "overrides": {
    "ws": "^8.18.0",
    "node-fetch": "^2.7.0",
    "minimatch": "^10.0.0",
    "react-helmet-async": {
      "react": "$react"
    }
  }
}
